      <aliases enabled='yes' />
      <column caption='ADR (copy)' datatype='real' name='[ADR (copy)_1589407975665669]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10; IF [status] IN (&quot;Confirmed&quot;,&quot;Checked-Out&quot;) THEN [gross_room_revenue]&#13;&#10;&#13;&#10; ELSEIF [status] = &quot;Cancelled&quot;&#13;&#10; AND [rate_code_id] = &quot;RT_02&quot;&#13;&#10; THEN [gross_room_revenue]&#13;&#10; END&#13;&#10;)&#13;&#10;/&#13;&#10;COUNT(&#13;&#10; IF [status] IN (&quot;Confirmed&quot;,&quot;Checked-Out&quot;) THEN [date_key] END&#13;&#10;)' />
      </column>
      <column caption='day_of_week' datatype='string' name='[Calculation_0139700861784081]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='DATENAME(&apos;weekday&apos;, [date_key])' />
      </column>
      <column caption='weekend' datatype='string' name='[Calculation_0139700865589266]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [is_weekend] THEN &quot;weekend&quot;&#13;&#10;ELSE &quot;weekday&quot;&#13;&#10;END' />
      </column>
      <column caption='Median ADR' datatype='real' name='[Calculation_0139700869230611]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='WINDOW_MEDIAN([Calculation_1451143027429377])'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Cost of Acquisition' datatype='real' name='[Calculation_0139700875739157]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(IFNULL(SUM([commission_amount]), 0) + IFNULL(SUM([cost_amount]), 0)) / SUM([net_room_revenue])' />
      </column>
      <column caption='Is Promo' datatype='string' name='[Calculation_0701827480240128]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [rate_name] = &apos;Non-Refundable&apos; OR &#13;&#10;   [rate_name] = &apos;Seasonal Rate&apos; OR &#13;&#10;   [rate_name] = &apos;AAA Discount&apos; OR &#13;&#10;   [rate_name] = &apos;Member Discount&apos; &#13;&#10;THEN &apos;Promotion&apos; &#13;&#10;ELSE &apos;Non-Promotion&apos; &#13;&#10;END' />
      </column>
      <column caption='OCC' datatype='real' name='[Calculation_1451143019896832]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(&#13;&#10; IF [status] IN (&quot;Confirmed&quot;,&quot;Checked-Out&quot;)&#13;&#10; THEN [booking_id]&#13;&#10; END&#13;&#10;)&#13;&#10;/ SUM({ FIXED [date_key] : MAX([rooms_available_for_sale]) })' />
      </column>
      <column caption='ADR' datatype='real' name='[Calculation_1451143027429377]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// ตัวตั้ง: รวมรายได้ปกติ + รายได้จากการจองที่ Cancel แต่ไม่คืนเงิน&#13;&#10;SUM(&#13;&#10; IF [status] IN (&quot;Confirmed&quot;,&quot;Checked-Out&quot;) THEN [gross_room_revenue]&#13;&#10;&#13;&#10; ELSEIF [status] = &quot;Cancelled&quot;&#13;&#10; AND [rate_code_id] = &quot;RT_02&quot;&#13;&#10; THEN [gross_room_revenue]&#13;&#10; END&#13;&#10;)&#13;&#10;/&#13;&#10;COUNT(&#13;&#10; IF [status] IN (&quot;Confirmed&quot;,&quot;Checked-Out&quot;) THEN [date_key] END&#13;&#10;)' />
      </column>
      <column caption='Net ADR' datatype='real' name='[Calculation_1451143027654658]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10; IF [status] IN (&quot;Confirmed&quot;,&quot;Checked-Out&quot;) THEN [net_room_revenue]&#13;&#10;&#13;&#10; ELSEIF [status] = &quot;Cancelled&quot;&#13;&#10; AND [rate_code_id] = &quot;RT_02&quot;&#13;&#10; THEN [net_room_revenue]&#13;&#10; END&#13;&#10;)&#13;&#10;/&#13;&#10;COUNT(&#13;&#10; IF [status] IN (&quot;Confirmed&quot;,&quot;Checked-Out&quot;) THEN [date_key] END&#13;&#10;)' />
      </column>
      <column caption='Net RevPAR' datatype='real' name='[Calculation_1451143027892229]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10; IF [status] IN (&quot;Confirmed&quot;,&quot;Checked-Out&quot;) THEN [net_room_revenue]&#13;&#10;&#13;&#10; ELSEIF [status] = &quot;Cancelled&quot;&#13;&#10; AND [rate_code_id] = &quot;RT_02&quot;&#13;&#10; THEN [net_room_revenue]&#13;&#10; END&#13;&#10;)&#13;&#10;/&#13;&#10;SUM({ FIXED [date_key] : MAX([rooms_available_for_sale]) })' />
      </column>
      <column caption='Cancellation Rate' datatype='real' name='[Calculation_1589407887503360]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [status] = &quot;Cancelled&quot; THEN [booking_id] END)&#13;&#10;/&#13;&#10;COUNTD([booking_id])' />
      </column>
      <column caption='Net RevPAR (copy)' datatype='real' name='[Net RevPAR (copy)_1589407972352004]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1451143027654658] * [Calculation_1451143019896832]' />
      </column>
      <column caption='OCC (copy)' datatype='real' name='[OCC (copy)_1589407982460934]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(&#13;&#10; IF [status] IN (&quot;Confirmed&quot;,&quot;Checked-Out&quot;) THEN [date_key]&#13;&#10; ELSEIF [status] = &quot;Cancelled&quot; AND [rate_code_id] = &quot;RT_02&quot; THEN [date_key]&#13;&#10; END&#13;&#10;)&#13;&#10;/ SUM({ FIXED [date_key] : MAX([rooms_available_for_sale]) })' />
      </column>
