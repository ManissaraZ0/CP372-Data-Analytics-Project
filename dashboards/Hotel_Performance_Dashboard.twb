    <worksheet name='EDA4'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='TH Sarabun New' fontsize='14'>Net ADR ตามช่องทางการจอง</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Hotel Analytics' name='federated.1x517gi0hm7rn410mgvlh0y56cgc' />
          </datasources>
          <datasource-dependencies datasource='federated.1x517gi0hm7rn410mgvlh0y56cgc'>
            <column caption='Net ADR' datatype='real' name='[Calculation_1451143027654658]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(&#13;&#10; IF [status] IN (&quot;Confirmed&quot;,&quot;Checked-Out&quot;) THEN [net_room_revenue]&#13;&#10;&#13;&#10; ELSEIF [status] = &quot;Cancelled&quot;&#13;&#10; AND [rate_code_id] = &quot;RT_02&quot;&#13;&#10; THEN [net_room_revenue]&#13;&#10; END&#13;&#10;)&#13;&#10;/&#13;&#10;COUNT(&#13;&#10; IF [status] IN (&quot;Confirmed&quot;,&quot;Checked-Out&quot;) THEN [date_key] END&#13;&#10;)' />
            </column>
            <column caption='Channel Type' datatype='string' name='[channel_type]' role='dimension' type='nominal' />
            <column caption='Date Key' datatype='date' name='[date_key]' role='dimension' type='ordinal' />
            <column caption='Net Room Revenue' datatype='real' name='[net_room_revenue]' role='measure' type='quantitative' />
            <column-instance column='[channel_type]' derivation='None' name='[none:channel_type:nk]' pivot='key' type='nominal' />
            <column caption='Rate Code Id' datatype='string' name='[rate_code_id]' role='dimension' type='nominal' />
            <column caption='Status' datatype='string' name='[status]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_1451143027654658]' derivation='User' name='[usr:Calculation_1451143027654658:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <shelf-sorts>
            <shelf-sort-v2 dimension-to-sort='[federated.1x517gi0hm7rn410mgvlh0y56cgc].[none:channel_type:nk]' direction='DESC' is-on-innermost-dimension='true' measure-to-sort-by='[federated.1x517gi0hm7rn410mgvlh0y56cgc].[usr:Calculation_1451143027654658:qk]' shelf='columns' />
          </shelf-sorts>
          <aggregation value='true' />
