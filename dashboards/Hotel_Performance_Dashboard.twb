    <worksheet name='Hypo2.2'>
      <layout-options>
        <title>
          <formatted-text>
            <run>COA% by Channel</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Hotel Analytics' name='federated.1x517gi0hm7rn410mgvlh0y56cgc' />
          </datasources>
          <datasource-dependencies datasource='federated.1x517gi0hm7rn410mgvlh0y56cgc'>
            <column caption='Cost of Acquisition' datatype='real' name='[Calculation_0139700875739157]' role='measure' type='quantitative'>
