            <column caption='Is Weekend' datatype='boolean' name='[is_weekend]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_0139700865589266]' derivation='None' name='[none:Calculation_0139700865589266:nk]' pivot='key' type='nominal' />
            <column-instance column='[channel_type]' derivation='None' name='[none:channel_type:nk]' pivot='key' type='nominal' />
            <column caption='Rate Code Id' datatype='string' name='[rate_code_id]' role='dimension' type='nominal' />
