            <column caption='Rooms Available For Sale' datatype='integer' name='[rooms_available_for_sale]' role='measure' type='quantitative' />
            <column caption='Status' datatype='string' name='[status]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_1451143027429377]' derivation='User' name='[usr:Calculation_1451143027429377:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_1451143027654658]' derivation='User' name='[usr:Calculation_1451143027654658:qk]' pivot='key' type='quantitative' />
