              <calculation class='tableau' formula='SUM(&#13;&#10; IF [status] IN (&quot;Confirmed&quot;,&quot;Checked-Out&quot;) THEN [gross_room_revenue]&#13;&#10;&#13;&#10; ELSEIF [status] = &quot;Cancelled&quot;&#13;&#10; AND [rate_code_id] = &quot;RT_02&quot;&#13;&#10; THEN [gross_room_revenue]&#13;&#10; END&#13;&#10;)&#13;&#10;/&#13;&#10;COUNT(&#13;&#10; IF [status] IN (&quot;Confirmed&quot;,&quot;Checked-Out&quot;) THEN [date_key] END&#13;&#10;)' />
