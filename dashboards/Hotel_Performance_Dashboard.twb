            <column caption='ADR' datatype='real' name='[Calculation_1451143027429377]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='// ตัวตั้ง: รวมรายได้ปกติ + รายได้จากการจองที่ Cancel แต่ไม่คืนเงิน&#13;&#10;SUM(&#13;&#10; IF [status] IN (&quot;Confirmed&quot;,&quot;Checked-Out&quot;) THEN [gross_room_revenue]&#13;&#10;&#13;&#10; ELSEIF [status] = &quot;Cancelled&quot;&#13;&#10; AND [rate_code_id] = &quot;RT_02&quot;&#13;&#10; THEN [gross_room_revenue]&#13;&#10; END&#13;&#10;)&#13;&#10;/&#13;&#10;COUNT(&#13;&#10; IF [status] IN (&quot;Confirmed&quot;,&quot;Checked-Out&quot;) THEN [date_key] END&#13;&#10;)' />
            </column>
            <column caption='Channel Type' datatype='string' name='[channel_type]' role='dimension' type='nominal' />
