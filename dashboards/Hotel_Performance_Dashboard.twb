            <column-instance column='[Calculation_0139700869230611]' derivation='User' name='[usr:Calculation_0139700869230611:qk:2]' pivot='key' type='quantitative'>
              <table-calc ordering-field='[federated.1x517gi0hm7rn410mgvlh0y56cgc].[booking_date]' ordering-type='Field' />
