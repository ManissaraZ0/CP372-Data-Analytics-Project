    <worksheet name='EDA5'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='TH Sarabun New' fontsize='14'>Net RevPAR รายวัน (Weekday vs Weekend)</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Hotel Analytics' name='federated.1x517gi0hm7rn410mgvlh0y56cgc' />
          </datasources>
          <datasource-dependencies datasource='federated.1x517gi0hm7rn410mgvlh0y56cgc'>
            <column caption='Net RevPAR' datatype='real' name='[Calculation_1451143027892229]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(&#13;&#10; IF [status] IN (&quot;Confirmed&quot;,&quot;Checked-Out&quot;) THEN [net_room_revenue]&#13;&#10;&#13;&#10; ELSEIF [status] = &quot;Cancelled&quot;&#13;&#10; AND [rate_code_id] = &quot;RT_02&quot;&#13;&#10; THEN [net_room_revenue]&#13;&#10; END&#13;&#10;)&#13;&#10;/&#13;&#10;SUM({ FIXED [date_key] : MAX([rooms_available_for_sale]) })' />
            </column>
            <column caption='Channel Type' datatype='string' name='[channel_type]' role='dimension' type='nominal' />
            <column caption='Date' datatype='date' name='[date]' role='dimension' type='ordinal' />
            <column caption='Date Key' datatype='date' name='[date_key]' role='dimension' type='ordinal' />
            <column-instance column='[date]' derivation='Day' name='[dy:date:ok]' pivot='key' type='ordinal' />
            <column caption='Is Weekend' datatype='boolean' name='[is_weekend]' role='dimension' type='nominal' />
