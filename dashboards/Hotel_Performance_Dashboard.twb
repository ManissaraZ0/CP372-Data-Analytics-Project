    <worksheet name='Hypo2.3'>
      <layout-options>
        <title>
          <formatted-text>
            <run>OCC vs Net RevPAR by Channel</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Hotel Analytics' name='federated.1x517gi0hm7rn410mgvlh0y56cgc' />
